# AI-Powered Team Health Dashboard - Environment Variables
# Copy this file to .env.local and fill in your values

# AI Provider: "anthropic" or "ollama" (default: ollama if no ANTHROPIC_API_KEY)
# AI_PROVIDER=ollama

# Anthropic API key for Claude-powered analysis (only needed if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Ollama settings (only needed if AI_PROVIDER=ollama)
# Install Ollama: https://ollama.com, then run: ollama pull llama3
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# GitHub personal access token (needs repo scope)
GITHUB_TOKEN=
GITHUB_ORG=your-org
GITHUB_REPO=your-repo

# Linear API key (Settings > API > Personal API keys)
LINEAR_API_KEY=
LINEAR_TEAM_ID=

# Slack Bot OAuth token (needs channels:history, channels:read, users:read scopes)
SLACK_BOT_TOKEN=
# Comma-separated channel IDs to monitor (right-click channel > View channel details > copy ID)
SLACK_CHANNEL_IDS=

# DORA Metrics (uses GitHub credentials above)
# Deployment source: "deployments", "releases", or "auto" (default: auto)
# DORA_DEPLOYMENT_SOURCE=auto
# Environment to track for GitHub Deployments API (default: production)
# DORA_ENVIRONMENT=production
# Comma-separated GitHub issue labels that indicate incidents (for Change Failure Rate and MTTR)
# DORA_INCIDENT_LABELS=incident,hotfix,production-bug

# Shared data layer (team-data-core)
# Path to shared SQLite DB (default: ~/.local/share/team-data/data.db)
# TEAM_DATA_DB=

# OAuth App Credentials (optional — connect integrations via OAuth instead of API keys)
# GitHub: github.com/settings/developers > OAuth Apps > New OAuth App
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Linear: linear.app/settings/api/applications > Create OAuth application
# LINEAR_CLIENT_ID=
# LINEAR_CLIENT_SECRET=

# Slack: api.slack.com/apps > Create New App > OAuth & Permissions
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=

# Encryption key for OAuth tokens stored in SQLite (generate: openssl rand -base64 32)
# Required only when using OAuth — not needed for API key authentication
# OAUTH_ENCRYPTION_KEY=

# Base URL for OAuth callbacks (must match redirect URIs configured in provider apps)
# APP_BASE_URL=http://localhost:3000
